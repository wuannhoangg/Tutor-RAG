# ==========================================
# 1. CORE SYSTEM
# ==========================================
API_V1_STR=/api/v1
SECRET_KEY=a_very_long_random_secret_key_string
LOG_LEVEL=INFO
LOG_DIR=./logs

# ==========================================
# 2. DATABASE (Supabase Postgres)
# ==========================================
# LƯU Ý QUAN TRỌNG: Backend của bạn dùng Async, nên phải xài postgresql+asyncpg://
DATABASE_URL=postgresql+asyncpg://postgres.example:

# ==========================================
# 3. SUPABASE AUTH
# ==========================================
SUPABASE_URL=example.supabase.co
SUPABASE_JWT_SECRET=example_jwt_secret
SUPABASE_ANON_KEY=example_anon_key
# (Ghi chú: SUPABASE_ANON_KEY chủ yếu dùng cho Frontend, Backend không gọi tới nên không cần cấu hình)

# ==========================================
# 4. DEFAULT PLATFORM LLM (Mô hình dùng chung mặc định)
# ==========================================
PLATFORM_LLM_PROVIDER=google_ai
PLATFORM_LLM_API_KEY= example_google_api_key
PLATFORM_LLM_MODEL=gemma-4-31b-it
PLATFORM_LLM_BASE_URL=

# ==========================================
# 5. VECTOR STORE (Qdrant)
# ==========================================
# Tùy chọn A: Dùng Qdrant Cloud
QDRANT_URL=example_qdrant_url
QDRANT_API_KEY=example_qdrant_api_key

# Tùy chọn B: Dùng Local Docker (Nếu dùng thì xóa trống QDRANT_URL ở trên)
VECTOR_STORE_HOST=localhost
VECTOR_STORE_PORT=6333
VECTOR_STORE_API_KEY=